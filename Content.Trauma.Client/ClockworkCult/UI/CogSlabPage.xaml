<BoxContainer xmlns="https://spacestation14.io"
              xmlns:controls="using:Content.Client.UserInterface.Controls"
              Orientation="Horizontal">

    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True"
                  Margin="25 20">

        <Label Name="PageTitle"
               HorizontalAlignment="Center"
               StyleClasses="LabelBig"
               Margin="0 0 0 15" />

        <RichTextLabel Name="FirstPageContent"
                       HorizontalExpand="True"
                       Margin="10 0" />
    </BoxContainer>

    <controls:HLine Color="#555"
                    SetWidth="2"
                    VerticalExpand="True"
                    Margin="0 15" />

    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True"
                  Margin="25 20">
        <RichTextLabel Name="SecondPageContent"
                       HorizontalExpand="True"
                       Margin="10 0" />
    </BoxContainer>
</BoxContainer>
